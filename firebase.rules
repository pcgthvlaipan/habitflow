// ════════════════════════════════════════════════════════════════
// FIRESTORE SECURITY RULES
// Copy this into Firebase Console → Firestore → Rules
// ════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isValidHabit() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'uid', 'days', 'active'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 100
        && data.uid == request.auth.uid
        && data.days is list
        && data.active is bool;
    }

    function isValidCompletion() {
      let data = request.resource.data;
      return data.keys().hasAll(['habitId', 'dateKey', 'uid'])
        && data.uid == request.auth.uid
        && data.habitId is string
        && data.dateKey is string
        && data.dateKey.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

    // ── User documents ────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated() && isOwner(uid);
      allow write: if isAuthenticated() && isOwner(uid);

      // ── Habits subcollection ──────────────────────────────
      match /habits/{habitId} {
        allow read: if isAuthenticated() && isOwner(uid);
        allow create: if isAuthenticated() && isOwner(uid) && isValidHabit();
        allow update: if isAuthenticated() && isOwner(uid)
          && request.resource.data.uid == uid;
        allow delete: if isAuthenticated() && isOwner(uid);
      }

      // ── Completions subcollection ─────────────────────────
      match /completions/{completionId} {
        allow read: if isAuthenticated() && isOwner(uid);
        allow create: if isAuthenticated() && isOwner(uid) && isValidCompletion();
        allow delete: if isAuthenticated() && isOwner(uid);
        // No update — delete and recreate instead
        allow update: if false;
      }

      // ── Coach messages subcollection ──────────────────────
      match /coachMessages/{messageId} {
        allow read: if isAuthenticated() && isOwner(uid);
        allow create: if isAuthenticated() && isOwner(uid)
          && request.resource.data.keys().hasAll(['type', 'message'])
          && request.resource.data.type is string;
        allow update, delete: if false; // Messages are immutable
      }
    }

    // Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}


// ════════════════════════════════════════════════════════════════
// FIREBASE STORAGE SECURITY RULES
// Copy this into Firebase Console → Storage → Rules
// ════════════════════════════════════════════════════════════════

